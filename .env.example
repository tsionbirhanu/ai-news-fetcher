# --- Which AI enriches each article ---------------------------------------
# "auto" picks based on which key you set below: Gemini first (free!),
# then Claude, else the offline LSA summarizer. Force one with:
#   LLM_PROVIDER=gemini | claude | offline
LLM_PROVIDER=auto

# --- Google Gemini -------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Fetching & storage ----------------------------------------------------
DB_FILE=news.db
ARTICLES_PER_FEED=5
MAX_WORKERS=4             # parallel LLM requests

# --- Scheduler ---------------------------------------
FETCH_INTERVAL_MINUTES=30
DIGEST_HOUR=8            # 24h clock, local time — sends the daily digest

# --- Optional Telegram delivery -------------------------------------------
# See notifier.py for setup instructions. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
